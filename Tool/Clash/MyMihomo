# 重写规则 (从 Loon [Rewrite] 转换)
rewrites:
  - match: '^(http|https):\/\/(www.)?(g|google)\.cn'
    replace: 'https://www.google.com'
  - match: '^https?://(.*?[.])?(?:g|google).cn'
    replace: 'https://$1google.com'
  - match: '^(http|https):\/\/(ditu|maps).google\.cn'
    replace: 'https://maps.google.com'
  - match: '^http:\/\/t\.cn'
    replace: 'http://sinaurl.cn'
  - match: '^(http|https):\/\/nga\.178\.com'
    replace: 'https://ngabbs.com'
  - match: '^(http|https):\/\/bbs\.nga\.cn'
    replace: 'https://ngabbs.com'
  - match: '^https:\/\/zh.(m.)?wikipedia.org/zh(-\w*)?(?=/)'
    replace: 'https://www.wikiwand.com/zh$2'
  - match: '^https:\/\/(\w*).(m.)?wikipedia.org/wiki'
    replace: 'https://www.wikiwand.com/$1'
  - match: '^https?://union.click.jd.com/jda?'
    replace: 'http://union.click.jd.com/jda?adblock='
